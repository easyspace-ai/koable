{
  "$schema": "https://railway.app/railway.schema.json",
  "version": 2,
  "_comment": "Railway template config for Doable. All services pull pre-built images from ghcr.io (source-build OOMs on Railway's 8GB sandbox). Top-level build/deploy intentionally omitted — Railway uses per-service blocks below.",
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "services": {
    "api": {
      "source": {
        "image": "ghcr.io/doable-me/doable-api:latest"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "startCommand": "node /app/services/api/dist/db/migrate.js && exec tmux-entrypoint api npx tsx services/api/src/index.ts",
        "restartPolicyType": "ON_FAILURE"
      },
      "networking": {
        "servicePort": 4000
      },
      "variables": {
        "DATABASE_URL": "postgres://postgres:${{shared.POSTGRES_PASSWORD}}@${{doable-postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres",
        "JWT_SECRET": "${{shared.JWT_SECRET}}",
        "ENCRYPTION_KEY": "${{shared.ENCRYPTION_KEY}}",
        "INTERNAL_SECRET": "${{shared.INTERNAL_SECRET}}",
        "DOABLE_KEK": "${{shared.DOABLE_KEK}}",
        "INSTALL_BOOTSTRAP_TOKEN": "${{shared.INSTALL_BOOTSTRAP_TOKEN}}",
        "INSTALL_BOOTSTRAP_TOKEN_EXPIRES_AT": "${{shared.INSTALL_BOOTSTRAP_TOKEN_EXPIRES_AT}}",
        "API_PORT": "4000",
        "API_HOST": "0.0.0.0",
        "WS_PORT": "4001",
        "WS_HOST": "0.0.0.0",
        "API_URL": "http://${{api.RAILWAY_PRIVATE_DOMAIN}}:4000",
        "WS_INTERNAL_URL": "http://${{ws.RAILWAY_PRIVATE_DOMAIN}}:4001",
        "NEXT_PUBLIC_API_URL": "https://${{web.RAILWAY_PUBLIC_DOMAIN}}/api",
        "NEXT_PUBLIC_WS_URL": "wss://${{web.RAILWAY_PUBLIC_DOMAIN}}/ws",
        "NEXT_PUBLIC_APP_URL": "https://${{web.RAILWAY_PUBLIC_DOMAIN}}",
        "CORS_ORIGINS": "https://${{web.RAILWAY_PUBLIC_DOMAIN}}",
        "NODE_ENV": "production",
        "DOABLE_APP_DB_ENABLED": "1",
        "DOABLE_APP_AI_ENABLED": "1",
        "ANTHROPIC_API_KEY": "",
        "OPENAI_API_KEY": "",
        "GEMINI_API_KEY": "",
        "MINIMAX_API_KEY": "",
        "OPENROUTER_API_KEY": "",
        "TOGETHER_API_KEY": "",
        "FIREWORKS_API_KEY": "",
        "OPENCODE_ZEN_API_KEY": "",
        "GROQ_API_KEY": "",
        "CEREBRAS_API_KEY": "",
        "DEEPSEEK_API_KEY": "",
        "MISTRAL_API_KEY": "",
        "COHERE_API_KEY": "",
        "XAI_API_KEY": "",
        "PERPLEXITY_API_KEY": "",
        "DEEPINFRA_API_KEY": "",
        "NVIDIA_API_KEY": "",
        "MOONSHOT_API_KEY": "",
        "ZHIPU_API_KEY": "",
        "GITHUB_CLIENT_ID": "",
        "GITHUB_CLIENT_SECRET": "",
        "GOOGLE_CLIENT_ID": "",
        "GOOGLE_CLIENT_SECRET": "",
        "STRIPE_SECRET_KEY": "",
        "STRIPE_WEBHOOK_SECRET": ""
      }
    },
    "ws": {
      "source": {
        "image": "ghcr.io/doable-me/doable-ws:latest"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "networking": {
        "servicePort": 4001
      },
      "variables": {
        "DATABASE_URL": "postgres://postgres:${{shared.POSTGRES_PASSWORD}}@${{doable-postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres",
        "JWT_SECRET": "${{shared.JWT_SECRET}}",
        "INTERNAL_SECRET": "${{shared.INTERNAL_SECRET}}",
        "WS_PORT": "4001",
        "WS_HOST": "0.0.0.0",
        "API_URL": "http://${{api.RAILWAY_PRIVATE_DOMAIN}}:4000",
        "NODE_ENV": "production"
      }
    },
    "web": {
      "source": {
        "image": "ghcr.io/doable-me/doable-web:latest"
      },
      "networking": {
        "servicePort": 3000
      },
      "variables": {
        "NEXT_PUBLIC_API_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}/api",
        "NEXT_PUBLIC_WS_URL": "wss://${{RAILWAY_PUBLIC_DOMAIN}}/ws",
        "NEXT_PUBLIC_APP_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "HOSTNAME": "0.0.0.0",
        "PORT": "3000",
        "NODE_ENV": "production"
      }
    },
    "doable-postgres": {
      "source": {
        "image": "pgvector/pgvector:pg16"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "networking": {
        "servicePort": 5432
      },
      "variables": {
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "${{shared.POSTGRES_PASSWORD}}",
        "POSTGRES_DB": "postgres"
      },
      "volumes": [
        { "mountPath": "/var/lib/postgresql/data", "size": 10 }
      ]
    }
  },
  "shared": {
    "POSTGRES_PASSWORD": { "generator": "secret" },
    "JWT_SECRET": { "generator": "secret" },
    "ENCRYPTION_KEY": { "generator": "secret" },
    "INTERNAL_SECRET": { "generator": "secret" },
    "DOABLE_KEK": { "generator": "secret" },
    "INSTALL_BOOTSTRAP_TOKEN": { "generator": "secret" },
    "INSTALL_BOOTSTRAP_TOKEN_EXPIRES_AT": ""
  }
}
