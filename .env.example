# ─── Doable .env.example ──────────────────────────────────────
# Copy to .env and fill in. Generate secrets with `openssl rand -hex 32`.
# SECURITY: All hosts MUST bind to 127.0.0.1 — see CLAUDE.md.
# `setup-server.sh` writes a populated .env on fresh installs; this file is
# the canonical reference for every variable the codebase reads.
#
# Local dev (native Postgres, no Docker):
#   bash scripts/setup-local.sh && pnpm dev:local
# See docs/LOCAL_DEV.md

# ─── REQUIRED — Database ──────────────────────────────────────
DATABASE_URL=postgres://doable:doable_secret@localhost:5432/doable
# Optional: pool size for pg client (default 20)
# DATABASE_POOL_SIZE=20

# ─── REQUIRED — API server ────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=4000
# URL the WS server / internal tools use to reach API (defaults derived from above)
API_URL=http://127.0.0.1:4000
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── REQUIRED — WebSocket server ──────────────────────────────
WS_HOST=127.0.0.1
WS_PORT=4001
# Internal URL the API uses to push to WS (server-side only)
WS_INTERNAL_URL=http://127.0.0.1:4001

# ─── REQUIRED — Next.js frontend ──────────────────────────────
# Public URLs exposed to the browser. In prod these point at the
# Cloudflare-tunneled hostnames; in dev they hit localhost.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: Next.js basePath when hosted under a sub-path
# NEXT_PUBLIC_BASE_PATH=
# Optional: environment label shown in UI (development|preview|production)
# NEXT_PUBLIC_ENV=development
# Optional: server URL the API hands clients (falls back to NEXT_PUBLIC_APP_URL)
# FRONTEND_URL=
# PUBLIC_URL=
# Optional: Next.js host/port overrides (already set by package.json scripts)
# HOST=127.0.0.1
# PORT=3000

# ─── REQUIRED — Auth / JWT ────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ISSUER=doable
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
# Per-project JWT signing secret (used by sandboxed projects). Defaults to JWT_SECRET if unset.
# PROJECT_JWT_SECRET=

# ─── REQUIRED — Encryption / Internal auth ────────────────────
# Symmetric key used to encrypt OAuth tokens / secrets at rest. openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-random-encryption-key
# Encrypts user-provided integration credentials. Falls back to ENCRYPTION_KEY if unset.
# CREDENTIALS_ENCRYPTION_KEY=
# Shared secret API <-> WS server uses for internal RPC. openssl rand -hex 16
INTERNAL_SECRET=change-me-to-a-random-string
# Master Key-Encryption-Key for envelope-crypto. 32 raw bytes, base64-encoded.
# Generate with: openssl rand -base64 32
# Wraps per-workspace DEKs (workspace_keys table) and encrypts user-scoped
# MFA secrets (user_mfa_factors). DO NOT rotate after the first encrypted
# write — rotating orphans every existing ciphertext.
DOABLE_KEK=change-me-to-32-bytes-base64

# ─── REQUIRED — Storage paths ─────────────────────────────────
# Where per-user project workspaces live on disk
# Relative to services/api cwd when running `pnpm dev` from the monorepo root.
PROJECTS_ROOT=./projects
# Mirror of PROJECTS_ROOT used by the sandbox runner; keep them aligned
DOABLE_PROJECTS_DIR=./projects
# Where published static sites are written (Caddy serves from here)
SITES_DIR=./sites
# General-purpose data dir (uploads, thumbnails, caches)
# DATA_DIR=./data
# DOABLE_DATA_DIR=./data
# Optional: override the base directory the app considers "home"
# DOABLE_BASE_PATH=

# ─── REQUIRED — Environment ───────────────────────────────────
NODE_ENV=development
# Public-facing apex domain (e.g. doable.me). Used to compute *.subdomain URLs.
DOABLE_DOMAIN=localhost

# ─── Hardening level (optional, Wave 27) ──────────────────────
# Controls jailing across build (next build), dev-server (vite dev),
# and production systemd unit. Three values:
#   full     — production: per-project User=, PrivateUsers, ProtectKernel*,
#              SystemCallFilter, ProtectProc=invisible, etc. (default)
#   relaxed  — only baseline: NoNewPrivileges + ProtectSystem + PrivateTmp +
#              narrowed ReadWritePaths + IPAddressDeny=any. Dev-friendly.
#   off      — no hardening at all (debug only — runs as root, no FS scope)
# DOABLE_HARDENING=full
# DOABLE_HARDENING_LEVEL=prod
# DOABLE_SANDBOX_VITE=1

# ─── OAuth — GitHub (optional, Enter to skip in setup) ────────
# All three flows share a single GitHub OAuth App (or GitHub App). Register
# the Authorization callback URL as `http://localhost:4000/oauth/github/`
# (trailing slash) — GitHub's subdirectory-match rule then accepts every
# sub-path below: login, copilot, and repo.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:4000/oauth/github/login/callback
# GITHUB_COPILOT_REDIRECT_URI=http://localhost:4000/oauth/github/copilot/callback
# GITHUB_REPO_REDIRECT_URI=http://localhost:4000/oauth/github/repo/callback

# ─── OAuth — Google (optional) ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
# Separate OAuth app used for the integrations marketplace (kept distinct so sign-in scopes stay minimal)
# GOOGLE_INTEGRATIONS_CLIENT_ID=
# GOOGLE_INTEGRATIONS_CLIENT_SECRET=

# ─── OAuth — Integrations / MCP (optional) ────────────────────
# Redirect URI for generic third-party integration OAuth callbacks
# INTEGRATIONS_OAUTH_REDIRECT_URI=http://localhost:4000/integrations/oauth/callback
# Enhanced-auth flow (PKCE) callback for integrations
# INTEGRATIONS_ENHANCED_AUTH_REDIRECT_URI=http://localhost:4000/integrations/enhanced/callback
# Callback for MCP-host OAuth flows
# MCP_OAUTH_REDIRECT_URI=http://localhost:4000/mcp/oauth/callback

# ─── Supabase (optional — managed Postgres / auth bridge) ─────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── AI providers — BYOK fallback (optional) ──────────────────
# Used when a user hasn't connected GitHub Copilot / their own provider.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Copilot SDK / CLI (optional) ─────────────────────────────
# Default model the Copilot SDK requests (e.g. gpt-5, claude-sonnet-4.5)
# COPILOT_DEFAULT_MODEL=
# Path to a locally vendored `copilot` CLI binary (overrides PATH lookup)
# COPILOT_CLI_PATH=
# Self-hosted Copilot proxy URL (rarely set)
# COPILOT_CLI_URL=
# Idle ms before a per-project copilot engine is reaped
# DOCORE_IDLE_TIMEOUT_MS=600000
# Cap on concurrent copilot engine processes (default 8)
# MAX_CONCURRENT_ENGINES=8

# ─── Email (optional — only required to send mail) ────────────
# Provider: smtp | resend | google. Auto-detects from filled fields if unset.
# EMAIL_PROVIDER=
# EMAIL_FROM=Doable <noreply@localhost>
# Well-known SMTP service shortcut (gmail, sendgrid, mailgun, outlook365, yahoo, ...)
# EMAIL_SERVICE=
# Manual SMTP (used when EMAIL_SERVICE is empty)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Resend.com API key
# RESEND_API_KEY=
# Google Mail API (uses GOOGLE_CLIENT_ID/SECRET above + these two)
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_EMAIL_USER=

# ─── Billing — Stripe (optional) ──────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=
# STRIPE_BUSINESS_MONTHLY_PRICE_ID=
# STRIPE_BUSINESS_YEARLY_PRICE_ID=

# ─── Notifications — Slack (optional) ─────────────────────────
# Posts ops / alert events to a Slack channel
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# ─── Publish / Hosting — Caddy + Cloudflare Tunnel ────────────
# Path to the Caddyfile the publish service rewrites (prod default shown)
# CADDYFILE_PATH=/etc/caddy/Caddyfile
# Caddy admin API endpoint (used to reload config without restarts)
# CADDY_ADMIN_URL=http://127.0.0.1:2019
# Hostname the dev-server proxy advertises to running projects
# DEV_SERVER_HOST=127.0.0.1
# Idle-eviction: kill dev preview servers after this many ms of no
# preview-proxy traffic. Each idle Next.js dev session eats ~666 MB
# (next-server + launcher); evicting them keeps multi-tenant footprint
# bounded. Default 15 min. Set to 0 to disable eviction entirely.
# DEV_SERVER_IDLE_MS=900000
# How often the sweeper scans for idle servers (ms). Default 5 min.
# DEV_SERVER_SWEEP_INTERVAL_MS=300000
# Optional seccomp syscall filter for dev preview spawn. Default off
# (preserves debuggability for ptrace/strace/perf workflows). When on,
# dev processes get a kernel-level deny-list on
#   @debug @module @mount @raw-io @reboot @swap @privileged
# syscalls — closes the kernel-exploit escalation vector at the cost of
# making weird debugger workflows fail. Implementation wraps the dev
# spawn in `systemd-run --scope --property=SystemCallFilter=...` which
# preserves stdout/stderr (no journalctl detour). Toggle per-environment.
# DOABLE_DEV_SECCOMP=off
# Subdomain prefix for short auto-generated publish URLs (e.g. "p" → p-abc.doable.me)
# PUBLISH_SUBDOMAIN_PREFIX=p
# Cloudflare Tunnel ID — when set, the publish flow registers per-project DNS overrides.
# CLOUDFLARED_TUNNEL_ID=
# Same as above for the custom-domain flow (users CNAME → {ID}.cfargotunnel.com)
# CLOUDFLARE_TUNNEL_ID=
# Cloudflare API credentials (only needed if you let Doable manage DNS for you)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_PROJECT_NAME=

# ─── Per-project runtime — per-app DB + AI (optional overrides) ───────────────
# Per-app database: isolated PGlite DB via /__doable/data/* + doable.data MCP.
DOABLE_APP_DB_ENABLED=1
# Per-app AI: runtime chat/embed proxy at /__doable/ai/* + @doable/ai SDK in generated apps.
DOABLE_APP_AI_ENABLED=1
# Windows-only: path to vendored psroot.exe used by the Psroot sandbox backend
# DOABLE_PSROOT_PATH=
# Per-project Vite dev-server resource caps (Linux: cgroups; Mac: sandbox-exec)
# VITE_CPU_QUOTA=80%
# VITE_MEMORY_MAX=1G
# VITE_TASKS_MAX=200
# Buffer size for build log streaming (bytes)
# BUILD_BUFFER_SIZE=1048576

# ─── MCP / skills directories (optional overrides) ────────────
# Where bundled MCP server packages are unpacked
# DOABLE_MCP_SERVERS_DIR=./mcp-servers
# Where authoring "skills" (slash-command bundles) live
# DOABLE_SKILLS_DIR=./skills

# ─── Observability / tracing (optional) ───────────────────────
# Standard Node log level: trace|debug|info|warn|error
# LOG_LEVEL=info
# Doable tracing verbosity: 0 (off) → 3 (verbose). Mirrored to NEXT_PUBLIC_TRACING_LEVEL for the browser.
# TRACING_LEVEL=1
# NEXT_PUBLIC_TRACING_LEVEL=1
# Sample ratio 0.0 – 1.0 (default 1.0 in dev, lower in prod)
# TRACING_SAMPLE_RATIO=1.0
# Service name reported in spans (default derived from package.json)
# SERVICE_NAME=doable-api
# Git SHA stamped on every span / log line (set automatically in CI)
# BUILD_SHA=
# Verbose DB query logging
# DOABLE_DB_DEBUG=0
# DOABLE_DB_TRACE=0
# Log MCP server stdio for debugging
# MCP_DEBUG=0

# ─── Thumbnails — Puppeteer / Chrome (optional) ───────────────
# Headless Chrome for project preview screenshots. If unset, puppeteer uses
# its cache (~/.cache/puppeteer) or falls back to system Chrome on macOS.
# Install bundled Chrome (matches puppeteer version):
#   pnpm --filter @doable/api exec puppeteer browsers install chrome
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_CACHE_DIR=~/.cache/puppeteer
# CHROME_PATH=

# ─── Marketplace (optional) ───────────────────────────────────
# Disables the background job that refreshes the "featured" template list
# MARKETPLACE_DISABLE_FEATURED_REFRESHER=0

# ─── Rate limiting (optional overrides) ──────────────────────
# Defaults SHIPPED OFF (RATE_LIMIT_MAX=0). Doable sits behind Cloudflare
# Tunnel in production — Cloudflare already does DDoS / bot protection
# upstream, so the in-process limiter mostly punishes bursty legit users
# (OAuth flows, dashboard polls, etc.) without adding much defence.
#
# Always-exempt routes (regardless of RATE_LIMIT_MAX): /health,
# /visual-edit-bridge.js, /preview/*, /thumbnails/*, /analytics/*,
# /admin/*, /auth/*. Loopback (127.0.0.1, ::1) bypasses too, plus any
# non-production request without X-Forwarded-For (direct localhost dev).
#
# To turn it back on (e.g. running on a host without Cloudflare in front):
#   RATE_LIMIT_MAX=200          # requests per WINDOW_MS per authenticated user
#   RATE_LIMIT_WINDOW_MS=60000  # 60-second sliding window
RATE_LIMIT_MAX=0

# ─── Optional: Redis (shared rate limit / sessions) ───────────
# Leave empty to use the in-memory KV store (fine up to ~100 users).
# REDIS_URL=

# ─── Per-project runtime hardening (Wave 27-C) ────────────────
# Production hardening level (full = default, relaxed = dev-friendly, off = no hardening)
# DOABLE_HARDENING=full

# Sandbox orchestrator hardening level.
# Controls the jailedSpawn orchestrator's fail-closed behavior for the
# AI bash tool and Vite dev server sandbox. Values: off | dev | staging | prod.
# "prod" blocks non-isolating backends (direct, noop) and requires bubblewrap.
# DOABLE_HARDENING_LEVEL=prod

# Route Vite dev server through the full sandbox orchestrator (profile +
# backend + composers) instead of the legacy vault.spawn path.
# DOABLE_SANDBOX_VITE=1

# ─── Build-time outbound proxy (Wave 29 — optional, recommended) ──────
# When set, every `next build` / `npm install` / `pip install` routes
# through this proxy. Run scripts/setup-build-proxy.sh to install Squid
# with a sensible default allow-list (npmjs.org, pypi.org, github.com).
# BUILD_HTTP_PROXY=http://127.0.0.1:3128

# ─── First-run bootstrap (auto-generated by setup-server.sh) ──
# Single-use token for first-user admin promotion. Empty in .env.example.
# setup-server.sh generates this at install time; in development the
# first user to sign up against an empty `users` table is auto-promoted
# without a token being required.
# INSTALL_BOOTSTRAP_TOKEN=
# INSTALL_BOOTSTRAP_TOKEN_EXPIRES_AT=
