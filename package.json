{
  "name": "doable",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:local": "turbo run dev --filter=@doable/web --filter=@doable/api",
    "dev:stop": "pkill -f 'next dev|tsx watch|turbo run dev' 2>/dev/null; for p in 3000 4000; do lsof -ti:$p | xargs kill -9 2>/dev/null; done; echo 'Stopped dev servers (ports 3000/4000)'",
    "dev:web": "turbo run dev --filter=@doable/web",
    "dev:api": "turbo run dev --filter=@doable/api",
    "dev:ws": "turbo run dev --filter=@doable/ws",
    "setup:local": "bash scripts/setup-local.sh",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:contracts": "node scripts/run-contract-tests.mjs",
    "smoke:admin": "node scripts/smoke-admin.mjs",
    "type-check": "turbo run type-check",
    "db:migrate": "turbo run db:migrate --filter=@doable/api",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "yjs": "^13.6.30"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": "1.29.0",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "argon2",
      "better-sqlite3",
      "bufferutil",
      "canvas",
      "esbuild",
      "puppeteer",
      "secp256k1",
      "sharp",
      "utf-8-validate"
    ]
  }
}
