# ═══════════════════════════════════════════════════════════════════
# Doable Integration OAuth Credentials
# ═══════════════════════════════════════════════════════════════════
#
# This file lists all OAuth2 integrations that need platform-level
# credentials. See tools/setup-oauth-providers.md for setup instructions.
#
# Redirect URI for ALL integrations:
#   Local:      http://127.0.0.1:4000/integrations/oauth/callback
#   Production: https://api.doable.me/integrations/oauth/callback
#
# Override with: INTEGRATIONS_OAUTH_REDIRECT_URI=https://...
#

# ── Google Services (google_sheets, googlechat, gmail, google_docs, google_calendar, google_drive, google_contacts, google_forms, google_tasks, google_cloud_storage, youtube, google_vertexai) ──
# 1 OAuth app covers ALL Google integrations (separate from the login GOOGLE_CLIENT_ID)
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback (dev)
#               https://api.doable.me/integrations/oauth/callback (prod)
# Scopes: https://www.googleapis.com/auth/spreadsheets, https://www.googleapis.com/auth/chat.messages, https://www.googleapis.com/auth/gmail.send, https://www.googleapis.com/auth/gmail.readonly, https://www.googleapis.com/auth/gmail.compose, https://www.googleapis.com/auth/documents, https://www.googleapis.com/auth/calendar.events, https://www.googleapis.com/auth/drive, https://www.googleapis.com/auth/contacts, https://www.googleapis.com/auth/forms.body.readonly, https://www.googleapis.com/auth/tasks, https://www.googleapis.com/auth/devstorage.full_control, https://www.googleapis.com/auth/youtube, https://www.googleapis.com/auth/cloud-platform
# NOTE: This is SEPARATE from GOOGLE_CLIENT_ID used for "Sign in with Google".
#       Keep login OAuth minimal (openid email profile) and this one for integrations.
GOOGLE_INTEGRATIONS_CLIENT_ID=
GOOGLE_INTEGRATIONS_CLIENT_SECRET=

# ── Microsoft Services (microsoft_teams, microsoft_outlook) ──
# 1 Azure AD app covers: microsoft_teams, microsoft_outlook
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: Chat.ReadWrite, ChannelMessage.Send, User.Read, Mail.Send, Mail.Read
# (All can point to the same OAuth app)
OAUTH_MICROSOFT_TEAMS_CLIENT_ID=
OAUTH_MICROSOFT_TEAMS_CLIENT_SECRET=
OAUTH_MICROSOFT_OUTLOOK_CLIENT_ID=
OAUTH_MICROSOFT_OUTLOOK_CLIENT_SECRET=

# ── GitHub (github) ──
# Already configured for git sync -- just add the redirect URI
# Create at: https://github.com/settings/developers
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: repo, read:user
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Atlassian (Jira + Confluence) (jira_cloud, confluence) ──
# 1 Atlassian OAuth app covers: jira_cloud, confluence
# Create at: https://developer.atlassian.com/console/myapps/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: read:jira-work, write:jira-work, read:confluence-content.all, write:confluence-content
# (All can point to the same OAuth app)
OAUTH_JIRA_CLOUD_CLIENT_ID=
OAUTH_JIRA_CLOUD_CLIENT_SECRET=
OAUTH_CONFLUENCE_CLIENT_ID=
OAUTH_CONFLUENCE_CLIENT_SECRET=

# ── Meta (Facebook + Instagram) (instagram_business, facebook_pages) ──
# 1 Meta app can cover: instagram_business, facebook_pages
# Create at: https://developers.facebook.com/apps/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: instagram_basic, instagram_content_publish, pages_manage_posts, pages_read_engagement
# (All can point to the same OAuth app)
OAUTH_INSTAGRAM_BUSINESS_CLIENT_ID=
OAUTH_INSTAGRAM_BUSINESS_CLIENT_SECRET=
OAUTH_FACEBOOK_PAGES_CLIENT_ID=
OAUTH_FACEBOOK_PAGES_CLIENT_SECRET=

# ── Asana (asana) ──
# Create at: https://app.asana.com/0/developer-console
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: default
OAUTH_ASANA_CLIENT_ID=
OAUTH_ASANA_CLIENT_SECRET=

# ── Box (box) ──
# Create at: https://app.box.com/developers/console
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_BOX_CLIENT_ID=
OAUTH_BOX_CLIENT_SECRET=

# ── Constant Contact (constant_contact) ──
# Create at: https://developer.constantcontact.com/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_CONSTANT_CONTACT_CLIENT_ID=
OAUTH_CONSTANT_CONTACT_CLIENT_SECRET=

# ── DocuSign (docusign) ──
# Create at: https://admindemo.docusign.com/apps-and-keys
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: signature
OAUTH_DOCUSIGN_CLIENT_ID=
OAUTH_DOCUSIGN_CLIENT_SECRET=

# ── Dropbox (dropbox) ──
# Create at: https://www.dropbox.com/developers/apps
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_DROPBOX_CLIENT_ID=
OAUTH_DROPBOX_CLIENT_SECRET=

# ── GitLab (gitlab) ──
# Create at: https://gitlab.com/-/user_settings/applications
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: api
OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=

# ── HubSpot (hubspot) ──
# Create at: https://developers.hubspot.com/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
# Scopes: crm.objects.contacts.read, crm.objects.contacts.write, crm.objects.deals.read
OAUTH_HUBSPOT_CLIENT_ID=
OAUTH_HUBSPOT_CLIENT_SECRET=

# ── Intercom (intercom) ──
# Create at: https://developers.intercom.com/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_INTERCOM_CLIENT_ID=
OAUTH_INTERCOM_CLIENT_SECRET=

# ── Linear (linear) ──
# Create at: https://linear.app/settings/api
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
