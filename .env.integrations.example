OAUTH_QUICKBOOKS_CLIENT_ID=
OAUTH_QUICKBOOKS_CLIENT_SECRET=

# ── Reddit (reddit) ──
# Create at: https://www.reddit.com/prefs/apps
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
