# Create at: https://developers.pinterest.com/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_PINTEREST_CLIENT_ID=
OAUTH_PINTEREST_CLIENT_SECRET=

# ── Pipedrive (pipedrive) ──
# Create at: https://developers.pipedrive.com/
# Redirect URI: http://127.0.0.1:4000/integrations/oauth/callback
OAUTH_PIPEDRIVE_CLIENT_ID=
OAUTH_PIPEDRIVE_CLIENT_SECRET=

