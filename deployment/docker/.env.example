# ==============================================================================
# Doable — Docker Environment Variables
# ==============================================================================
# Copy this file to docker/.env and fill in your values:
#   cp docker/.env.example docker/.env
#
# Generate random secrets:
#   openssl rand -hex 32
# ==============================================================================

# ─── Secrets (REQUIRED — generate unique values!) ──────────
JWT_SECRET=change-me-run-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32
INTERNAL_SECRET=change-me-run-openssl-rand-hex-32
# Master KEK for envelope-crypto (per-workspace DEKs + user MFA secrets).
# 32 raw bytes, base64-encoded → 44 chars. Generate with: openssl rand -base64 32
# DO NOT rotate after the first encrypted write — every workspace_keys row
# becomes orphaned (data loss). Missing → API throws 500 on MFA enroll
# and any KEK-decrypt path.
DOABLE_KEK=change-me-run-openssl-rand-base64-32

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=doable
POSTGRES_PASSWORD=change-me-run-openssl-rand-hex-16
POSTGRES_DB=doable

# ─── URLs (change if using a reverse proxy / domain) ──────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Redis (optional — leave empty for in-memory) ─────────
# Set this and use --profile redis to enable Redis-backed rate limiting & sessions:
#   docker compose -f docker/docker-compose.yml --profile redis up --build
REDIS_URL=

# ─── AI (optional — set at least one for AI features) ─────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Per-app database (PGlite via /__doable/data/* + doable.data MCP). ON by default.
DOABLE_APP_DB_ENABLED=1
# Per-app AI runtime (/__doable/ai/*, @doable/ai SDK). ON by default.
DOABLE_APP_AI_ENABLED=1

# ─── OAuth (optional) ─────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe (optional) ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
