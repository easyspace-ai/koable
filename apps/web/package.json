{
  "name": "@doable/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1",
    "dev:turbo": "next dev --turbopack --hostname 127.0.0.1",
    "dev:webpack": "next dev --webpack --hostname 127.0.0.1",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');const dst=p.join('.next','standalone','apps','web');if(!fs.existsSync(p.join(dst,'.next')))process.exit(0);fs.cpSync('.next/static',p.join(dst,'.next','static'),{recursive:true});if(fs.existsSync('public'))fs.cpSync('public',p.join(dst,'public'),{recursive:true});console.log('[postbuild] copied static + public into standalone output');\"",
    "build:cf": "npx @opennextjs/cloudflare build",
    "preview:cf": "npx wrangler dev",
    "deploy:cf": "npx wrangler pages deploy",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@doable/marketplace-bundle": "workspace:*",
    "@doable/ai": "workspace:*",
    "@doable/shared": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^1.30.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation": "^0.57.0",
    "@opentelemetry/instrumentation-fetch": "^0.57.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-web": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.0",
    "next-intl": "^4.13.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.73.0",
    "y-monaco": "^0.1.6"
  }
}
